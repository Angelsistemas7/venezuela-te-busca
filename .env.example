# ─────────────────────────────────────────────────────────────
# Copia este archivo a ".env.local" y rellena los valores reales.
# Mientras estén vacíos, la app funciona con DATOS DE EJEMPLO en memoria.
# ─────────────────────────────────────────────────────────────

# Supabase (base de datos + almacenamiento de fotos)
# Las consigues en: https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (SOLO en el servidor, nunca exponer en el cliente).
# Se usa para verificar reportes y operaciones administrativas.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (anti-bot / anti-abuso, gratuito)
# Lo creas en: https://dash.cloudflare.com -> Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Contraseña del panel de moderación (/admin).
# Si la dejas vacía, el panel queda ABIERTO en modo demostración.
ADMIN_TOKEN=

# URL pública del sitio (p. ej. https://venezuelatebusca.org). Se usa para que la
# imagen de previsualización al compartir (WhatsApp, redes) y los enlaces sociales
# sean absolutos. En Vercel se detecta sola; defínela si usas otro dominio.
NEXT_PUBLIC_SITE_URL=
