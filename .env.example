# ─────────────────────────────────────────────────────────────
# Copia este archivo a ".env.local" y rellena los valores reales.
# Mientras estén vacíos, la app funciona con DATOS DE EJEMPLO en memoria.
# ─────────────────────────────────────────────────────────────

# Supabase (base de datos + almacenamiento de fotos)
# Las consigues en: https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (SOLO en el servidor, nunca exponer en el cliente).
# Se usa para verificar reportes y operaciones administrativas.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (anti-bot / anti-abuso, gratuito)
# Lo creas en: https://dash.cloudflare.com -> Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Contraseña del panel de moderación (/admin).
# Si la dejas vacía, el panel queda ABIERTO en modo demostración.
ADMIN_TOKEN=

# Modo mantenimiento (temporal): en "true", todo el sitio muestra /mantenimiento
# excepto /admin y quien ya inició sesión ahí con ADMIN_TOKEN. Déjalo vacío o
# en "false" para que el sitio funcione con normalidad.
MAINTENANCE_MODE=

# URL pública del sitio (p. ej. https://venezuelatebusca.org). Se usa para que la
# imagen de previsualización al compartir (WhatsApp, redes) y los enlaces sociales
# sean absolutos. En Vercel se detecta sola; defínela si usas otro dominio.
NEXT_PUBLIC_SITE_URL=

# Clave para el cron que "calienta" la caché de noticias cada hora
# (GET /api/cron/warm-news?secret=...). Si la dejas vacía, el endpoint queda
# abierto sin clave (solo consulta APIs públicas, sin riesgo de datos, pero
# es mejor ponerle una en producción para que nadie más lo llame a lo loco).
CRON_SECRET=

# OpenAI (gpt-4o-mini): traduce al español los titulares de noticias en otro
# idioma (src/lib/news.ts) y modera/traduce los posts importados por hashtag
# (scripts/fetch-social-posts.mjs). Opcional en ambos casos: sin esto, las
# noticias se muestran en su idioma original y los posts importados no se
# pre-moderan ni traducen, sin romper nada.
OPENAI_API_KEY=

# ── Ingesta automática de redes sociales por hashtag (scripts/fetch-social-posts.mjs) ──
# Todas opcionales, con valores por defecto razonables si se dejan vacías.
# Hashtags a buscar, separados por coma. Default: "TerremotoVE,TerremotoVenezuela"
SOCIAL_HASHTAGS=
# Instancias Mastodon a consultar, separadas por coma. Default: "mastodon.social"
MASTODON_INSTANCES=
# Cuenta de Bluesky: SIN esto, la búsqueda por hashtag en Bluesky no trae
# resultados (su endpoint público de búsqueda exige sesión). Mastodon sí
# funciona sin nada de esto. Gratis en bsky.app -> Ajustes -> App passwords.
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
